# Required for a real Qwen Cloud run. Never commit this value.
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen3.7-plus
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Optional. Enables CockroachDB-backed durable memory in cloud deployments.
# Keep the real URL in an encrypted Function Compute environment variable.
DATABASE_URL=
# Deployment-only fallback for runtimes that cannot resolve the DB hostname.
# DATABASE_URL remains the TLS authority; this must be a current endpoint IP.
DATABASE_HOSTADDR=

# Optional public-demo gate. Keep it out of source control and share it only
# in the private testing instructions for evaluators.
DEMO_ACCESS_CODE=

# Local development only. Do not use mock mode for a hackathon demo.
DEMO_MODE=mock
PORT=8787
